PORT=8787
# demo = simulated data, public = public Yahoo endpoints, tradier = broker/options API
DATA_PROVIDER=public
WATCHLIST=NVDA,TSLA,TQQQ,QQQ,AAPL,MSFT,AMZN,GOOGL,META,AMD
POLL_SECONDS=60

# Signal thresholds. IV values are decimals: 0.36 means 36%.
VIX_BUY_MAX=17
VIX_SELL_MIN=20
VIX_RISK_OFF=24
IV_BUY_PERCENTILE_MAX=35
IV_SELL_PERCENTILE_MIN=70
IV_SPIKE_POINTS=4
IV_CRUSH_POINTS=-3

# Tradier optional live provider.
# DATA_PROVIDER=tradier
# TRADIER_TOKEN=replace_me
# TRADIER_BASE_URL=https://api.tradier.com/v1
# TRADIER_VIX_SYMBOL=VIX
# TRADIER_OPTION_MONTHS=1

# Public provider. Uses Yahoo chart/options endpoints and estimates 30D ATM IV
# from the nearest available option expiration. No token required, but public
# endpoints can throttle or change without notice.
PUBLIC_USER_AGENT=Mozilla/5.0

# Email alerts. Use SMTP_SSL=true for port 465, false for STARTTLS/port 587.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SSL=true
SMTP_USER=you@example.com
SMTP_PASS=app_password_here
ALERT_FROM=you@example.com
ALERT_TO=you@example.com
ALERT_COOLDOWN_MINUTES=90
